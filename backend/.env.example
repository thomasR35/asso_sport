# ──────────────────────────────────────────────
#  Fichier de configuration — À COPIER en .env
#  Le fichier .env NE DOIT PAS être commité sur Git.
#  Ce fichier .env.example sert de modèle.
# ──────────────────────────────────────────────

# ── Application ────────────────────────────────
APP_NAME="AS Dynamo"
APP_ENV=development
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ── Base de données ────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=as_dynamo
DB_USER=root
DB_PASSWORD=

# ── Sécurité JWT ───────────────────────────────
# Générer avec : php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=REMPLACER_PAR_UNE_CLE_SECRETE_LONGUE
JWT_ACCESS_EXPIRY=900        # 15 minutes en secondes
JWT_REFRESH_EXPIRY=604800    # 7 jours en secondes

# ── Email (PHPMailer) ──────────────────────────
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=votre_username
MAIL_PASSWORD=votre_password
MAIL_FROM_ADDRESS=noreply@asdynamo.fr
MAIL_FROM_NAME="AS Dynamo"
